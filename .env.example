# Copy to .env on each environment. Generate APP_KEY with `php artisan key:generate`.

APP_NAME="AfriPay HR"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOG_LEVEL=debug

# Database (MySQL on cPanel, SQLite for dev)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sessions / cache / queue
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false
CACHE_DRIVER=database
QUEUE_CONNECTION=database
QUEUE_DRIVER=database
BROADCAST_DRIVER=log

# Mail — leave blank to skip outbound mail (controller logs a warning, doesn't error)
MAIL_MAILER=smtp
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# Pusher (optional — leave blank if not broadcasting)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=

# Redis (optional — only needed if CACHE_DRIVER or SESSION_DRIVER is redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Production-only overrides ────────────────────────────────────────────
# On prod, flip these:
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://www.afripay-hr.co.zm
#   SESSION_SECURE_COOKIE=true
#   APP_LOG_LEVEL=warning
#   FORCE_HTTPS=true       (also add this line — used by the SSL redirect middleware)
